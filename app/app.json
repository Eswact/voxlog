{
  "expo": {
    "name": "VoxLog",
    "slug": "voxlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.anonymous.voxlog",
      "permissions": ["RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS", "READ_MEDIA_AUDIO", "READ_MEDIA_VIDEO", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Toplantı ses kaydı için mikrofon erişimi gerekiyor."
        }
      ],
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "Ses dosyalarını kaydetmek için medya erişimi gerekiyor.",
          "savePhotosPermission": "Ses dosyalarını cihaza kaydetmek için izin gerekiyor.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}